<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>500일 축하해요!</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;500;700&display=swap" rel="stylesheet">
  <style>
/* ===== 기본 설정 ===== */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

:root {
  --primary-color: #FFB5A7;
  --secondary-color: #FCD5CE;
  --accent-color: #F8EDEB;
  --bg-color: #FFF8F0;
  --text-color: #5D4E4E;
  --text-light: #8B7E7E;
  --white: #FFFFFF;
  --shadow: 0 4px 15px rgba(0, 0, 0, 0.08);
  --shadow-hover: 0 8px 25px rgba(0, 0, 0, 0.12);
}

body {
  font-family: 'Noto Sans KR', sans-serif;
  background-color: var(--bg-color);
  color: var(--text-color);
  line-height: 1.6;
  min-height: 100vh;
}

/* ===== 히어로 섹션 ===== */
.hero {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 50%, var(--accent-color) 100%);
  padding: 60px 20px;
  padding-top: 30px;
  position: relative;
  overflow: hidden;
}

/* ===== Spoon 배지 ===== */
.spoon-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-bottom: 20px;
  position: relative;
  z-index: 2;
}

.spoon-badge img {
  height: 45px;
  filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.15));
  mix-blend-mode: multiply;
  border-radius: 8px;
}

.spoon-badge span {
  background: #FF5252;
  color: white;
  font-size: 0.75rem;
  font-weight: 700;
  padding: 4px 10px;
  border-radius: 4px;
  letter-spacing: 1px;
  animation: livePulse 1.5s ease-in-out infinite;
  box-shadow: 0 2px 8px rgba(255, 82, 82, 0.4);
}

@keyframes livePulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.hero::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.1'%3E%3Ccircle cx='30' cy='30' r='4'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  pointer-events: none;
}

.hero-inner {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40px;
  max-width: 1200px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.hero-content {
  text-align: center;
  flex: 0 0 auto;
}

.hero-image {
  flex-shrink: 0;
}

.hero-image img {
  width: 280px;
  height: 350px;
  object-fit: cover;
  border-radius: 20px;
  box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
  border: 4px solid rgba(255, 255, 255, 0.6);
  transition: transform 0.3s ease;
}

.hero-image img:hover {
  transform: scale(1.03);
}

.hero-image-left img {
  transform: rotate(-3deg);
}

.hero-image-left img:hover {
  transform: rotate(0deg) scale(1.03);
}

.hero-image-right img {
  transform: rotate(3deg);
}

.hero-image-right img:hover {
  transform: rotate(0deg) scale(1.03);
}

.hearts-decoration {
  margin-bottom: 20px;
  animation: float 3s ease-in-out infinite;
}

.heart {
  font-size: 2rem;
  color: #C94C4C;
  margin: 0 10px;
  display: inline-block;
  text-shadow: 0 2px 8px rgba(255, 255, 255, 0.8);
}

.heart:nth-child(1) { animation: heartbeat 1.5s ease-in-out infinite; }
.heart:nth-child(2) { animation: heartbeat 1.5s ease-in-out infinite 0.3s; }
.heart:nth-child(3) { animation: heartbeat 1.5s ease-in-out infinite 0.6s; }

.hero-title {
  font-size: 3rem;
  color: #8B4D5C;
  text-shadow: 0 2px 4px rgba(255, 255, 255, 0.6), 0 0 20px rgba(255, 255, 255, 0.4);
  margin-bottom: 15px;
}

.title-number {
  font-size: 4.5rem;
  font-weight: 700;
  display: block;
  color: #6B3A4A;
  text-shadow: 0 3px 6px rgba(255, 255, 255, 0.8), 0 0 30px rgba(255, 255, 255, 0.5);
  animation: glow 2s ease-in-out infinite alternate;
}

.title-text {
  display: block;
  font-weight: 600;
  color: #7A4555;
}

.hero-subtitle {
  font-size: 1.1rem;
  color: #6B4A52;
  text-shadow: 0 1px 3px rgba(255, 255, 255, 0.7);
  margin-top: 10px;
  font-weight: 500;
}

.hero-from {
  font-size: 1rem;
  color: #7A5560;
  text-shadow: 0 1px 3px rgba(255, 255, 255, 0.6);
  margin-top: 15px;
  font-weight: 600;
  font-style: italic;
}

.stars-decoration {
  margin-top: 25px;
}

.star {
  font-size: 1.5rem;
  color: #B85C5C;
  margin: 0 8px;
  text-shadow: 0 2px 6px rgba(255, 255, 255, 0.7);
  animation: twinkle 2s ease-in-out infinite;
}

.star:nth-child(2) { animation-delay: 0.5s; }
.star:nth-child(3) { animation-delay: 1s; }

/* ===== 컨테이너 ===== */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px 20px;
}

/* ===== 섹션 공통 ===== */
.section {
  background: var(--white);
  border-radius: 24px;
  padding: 40px;
  margin-bottom: 40px;
  box-shadow: var(--shadow);
}

.section-title {
  font-size: 1.8rem;
  color: var(--text-color);
  margin-bottom: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-title .icon {
  font-size: 1.5rem;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 15px;
  margin-bottom: 10px;
}

.section-header .section-title {
  margin-bottom: 5px;
}

.section-header .section-desc {
  margin-bottom: 0;
}

.btn-my-messages {
  background: linear-gradient(135deg, #A8D5BA 0%, #7EC8A3 100%);
  color: white;
  padding: 10px 20px;
  border: none;
  border-radius: 12px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 8px;
  box-shadow: 0 4px 15px rgba(126, 200, 163, 0.4);
  transition: all 0.3s ease;
}

.btn-my-messages:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(126, 200, 163, 0.5);
}

.section-desc {
  color: var(--text-light);
  margin-bottom: 30px;
}

/* ===== 업로드 영역 ===== */
.upload-area {
  border: 3px dashed var(--secondary-color);
  border-radius: 16px;
  padding: 50px;
  text-align: center;
  cursor: pointer;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, var(--accent-color) 0%, var(--white) 100%);
}

.upload-area:hover,
.upload-area.dragover {
  border-color: var(--primary-color);
  background: linear-gradient(135deg, var(--secondary-color) 0%, var(--accent-color) 100%);
  transform: scale(1.01);
}

.upload-icon {
  font-size: 4rem;
  margin-bottom: 15px;
}

.upload-text {
  font-size: 1.2rem;
  color: var(--text-color);
  margin-bottom: 8px;
}

.upload-hint {
  font-size: 0.9rem;
  color: var(--text-light);
}

/* ===== 업로드 폼 ===== */
.upload-form {
  margin-top: 20px;
  padding: 20px;
  background: var(--accent-color);
  border-radius: 12px;
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  align-items: center;
}

.selected-file {
  flex: 1;
  min-width: 200px;
  padding: 12px 15px;
  background: var(--white);
  border-radius: 8px;
  font-size: 0.95rem;
  color: var(--text-color);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ===== 입력 필드 ===== */
.input-field {
  padding: 12px 18px;
  border: 2px solid var(--secondary-color);
  border-radius: 12px;
  font-size: 1rem;
  font-family: inherit;
  outline: none;
  transition: all 0.3s ease;
  background: var(--white);
}

.input-field:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4px rgba(255, 181, 167, 0.2);
}

.textarea-field {
  width: 100%;
  padding: 15px 18px;
  border: 2px solid var(--secondary-color);
  border-radius: 12px;
  font-size: 1rem;
  font-family: inherit;
  outline: none;
  resize: vertical;
  min-height: 120px;
  transition: all 0.3s ease;
  background: var(--white);
}

.textarea-field:focus {
  border-color: var(--primary-color);
  box-shadow: 0 0 0 4px rgba(255, 181, 167, 0.2);
}

/* ===== 버튼 ===== */
.btn {
  padding: 14px 32px;
  border: none;
  border-radius: 12px;
  font-size: 1.05rem;
  font-family: inherit;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #E8837C 0%, #D4726B 100%);
  color: var(--white);
  box-shadow: 0 6px 20px rgba(216, 114, 107, 0.5);
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
}

.btn-primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 8px 25px rgba(216, 114, 107, 0.6);
  background: linear-gradient(135deg, #D4726B 0%, #C9615A 100%);
}

.btn-secondary {
  background: var(--white);
  color: var(--text-color);
  border: 2px solid var(--secondary-color);
}

.btn-secondary:hover {
  background: var(--accent-color);
}

/* ===== 미디어 갤러리 ===== */
.media-gallery {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 25px;
  margin-top: 30px;
}

.media-card {
  background: var(--white);
  border-radius: 16px;
  overflow: hidden;
  box-shadow: var(--shadow);
  transition: all 0.3s ease;
  position: relative;
}

.media-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-hover);
}

.media-actions {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  gap: 5px;
  opacity: 0;
  transition: opacity 0.2s ease;
  z-index: 10;
}

.media-card:hover .media-actions {
  opacity: 1;
}

.media-password-input {
  letter-spacing: 5px;
  text-align: center;
}

.media-card video,
.media-card audio {
  width: 100%;
  display: block;
}

.media-card video {
  aspect-ratio: 16 / 9;
  object-fit: cover;
  background: #000;
}

.media-card audio {
  padding: 20px;
  background: linear-gradient(135deg, var(--accent-color) 0%, var(--secondary-color) 100%);
}

.media-info {
  padding: 15px 20px;
  border-top: 1px solid var(--accent-color);
}

.media-nickname {
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 5px;
}

.media-date {
  font-size: 0.85rem;
  color: var(--text-light);
}

/* ===== 메시지 폼 ===== */
.message-form {
  display: flex;
  flex-direction: column;
  gap: 15px;
  max-width: 600px;
  margin: 0 auto 40px;
  background: linear-gradient(135deg, #FFF5F3 0%, #FFEEE8 100%);
  padding: 30px;
  border-radius: 20px;
  border: 2px solid var(--secondary-color);
}

.message-form .input-field {
  width: 100%;
}

.message-form .btn-primary {
  padding: 16px 40px;
  font-size: 1.15rem;
  margin-top: 10px;
  align-self: center;
}

/* ===== 롤링페이퍼 ===== */
.rolling-paper {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  justify-content: center;
  padding: 20px 0;
}

.message-card {
  width: 220px;
  min-height: 180px;
  padding: 20px;
  border-radius: 4px;
  box-shadow: 3px 3px 10px rgba(0, 0, 0, 0.1);
  position: relative;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
}

.message-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40px;
  height: 15px;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 0 0 8px 8px;
}

.message-card:hover {
  transform: rotate(0deg) scale(1.05) !important;
  z-index: 10;
  box-shadow: 5px 5px 20px rgba(0, 0, 0, 0.15);
}

.message-nickname {
  font-weight: 700;
  font-size: 1rem;
  margin-bottom: 10px;
  color: rgba(0, 0, 0, 0.7);
}

.message-content {
  flex: 1;
  font-size: 0.95rem;
  line-height: 1.5;
  color: rgba(0, 0, 0, 0.6);
  word-break: break-word;
}

.message-date {
  font-size: 0.75rem;
  color: rgba(0, 0, 0, 0.4);
  margin-top: 10px;
  text-align: right;
}

.message-actions {
  position: absolute;
  top: 8px;
  right: 8px;
  display: flex;
  gap: 5px;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.message-card:hover .message-actions {
  opacity: 1;
}

.action-btn {
  width: 28px;
  height: 28px;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.85rem;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  background: rgba(255, 255, 255, 0.8);
}

.action-btn:hover {
  transform: scale(1.1);
}

.edit-btn:hover {
  background: #FFF3CD;
}

.delete-btn:hover {
  background: #FFCDD2;
}

.edit-input {
  width: 100%;
  padding: 8px;
  border: 2px solid var(--primary-color);
  border-radius: 6px;
  font-family: inherit;
  font-size: 0.9rem;
  background: var(--white);
  outline: none;
}

.edit-nickname {
  font-weight: 600;
}

.edit-content {
  min-height: 80px;
  resize: vertical;
}

.edit-actions {
  display: flex;
  gap: 8px;
  margin-top: 10px;
}

.edit-save-btn,
.edit-cancel-btn {
  flex: 1;
  padding: 8px 12px;
  border: none;
  border-radius: 6px;
  font-family: inherit;
  font-size: 0.85rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s ease;
}

.edit-save-btn {
  background: #81C784;
  color: white;
}

.edit-save-btn:hover {
  background: #66BB6A;
}

.edit-cancel-btn {
  background: #E0E0E0;
  color: #666;
}

.edit-cancel-btn:hover {
  background: #BDBDBD;
}

@keyframes fadeOut {
  from { opacity: 1; transform: scale(1); }
  to { opacity: 0; transform: scale(0.8); }
}

.password-field {
  position: relative;
  width: 100%;
}

.password-field .input-field {
  width: 100%;
  letter-spacing: 8px;
  text-align: center;
  font-size: 1.2rem;
}

.password-hint {
  display: block;
  font-size: 0.8rem;
  color: var(--text-light);
  margin-top: 5px;
  text-align: center;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-overlay.active {
  display: flex;
}

.modal {
  background: var(--white);
  padding: 30px;
  border-radius: 20px;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  max-width: 350px;
  width: 90%;
  text-align: center;
  animation: modalIn 0.3s ease;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(-20px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-title {
  font-size: 1.3rem;
  color: var(--text-color);
  margin-bottom: 10px;
}

.modal-desc {
  font-size: 0.95rem;
  color: var(--text-light);
  margin-bottom: 20px;
}

.modal-input {
  width: 100%;
  letter-spacing: 10px;
  text-align: center;
  font-size: 1.5rem;
  padding: 15px;
  margin-bottom: 20px;
}

.modal-actions {
  display: flex;
  gap: 10px;
}

.modal-actions .btn {
  flex: 1;
}

.modal-large {
  max-width: 600px;
  width: 95%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 2px solid var(--accent-color);
}

.modal-header .modal-title {
  margin: 0;
}

.modal-close-btn {
  background: none;
  border: none;
  font-size: 2rem;
  color: var(--text-light);
  cursor: pointer;
  line-height: 1;
  padding: 0;
  transition: color 0.2s ease;
}

.modal-close-btn:hover {
  color: var(--text-color);
}

.my-messages-list {
  overflow-y: auto;
  flex: 1;
  padding-right: 10px;
}

.my-message-item {
  background: var(--accent-color);
  border-radius: 12px;
  padding: 15px;
  margin-bottom: 15px;
  position: relative;
}

.my-message-item:last-child {
  margin-bottom: 0;
}

.my-message-nickname {
  font-weight: 700;
  color: var(--text-color);
  margin-bottom: 8px;
  font-size: 1rem;
}

.my-message-content {
  color: var(--text-color);
  line-height: 1.5;
  margin-bottom: 10px;
  word-break: break-word;
}

.my-message-date {
  font-size: 0.8rem;
  color: var(--text-light);
}

.my-message-actions {
  position: absolute;
  top: 10px;
  right: 10px;
  display: flex;
  gap: 5px;
}

.my-message-delete-btn {
  background: #FFCDD2;
  border: none;
  border-radius: 6px;
  padding: 5px 10px;
  font-size: 0.8rem;
  cursor: pointer;
  transition: background 0.2s ease;
}

.my-message-delete-btn:hover {
  background: #EF9A9A;
}

.my-messages-empty {
  text-align: center;
  padding: 40px 20px;
  color: var(--text-light);
}

.my-messages-empty-icon {
  font-size: 3rem;
  margin-bottom: 15px;
}

/* ===== 푸터 ===== */
.footer {
  text-align: center;
  padding: 30px;
  color: var(--text-light);
  font-size: 0.9rem;
}

/* ===== 로딩 오버레이 ===== */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 248, 240, 0.95);
  display: none;
  justify-content: center;
  align-items: center;
  flex-direction: column;
  gap: 20px;
  z-index: 1000;
}

.loading-overlay.active {
  display: flex;
}

.loading-spinner {
  width: 50px;
  height: 50px;
  border: 4px solid var(--secondary-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* ===== 토스트 메시지 ===== */
.toast {
  position: fixed;
  bottom: 30px;
  left: 50%;
  transform: translateX(-50%) translateY(100px);
  background: var(--text-color);
  color: var(--white);
  padding: 15px 30px;
  border-radius: 12px;
  font-size: 0.95rem;
  opacity: 0;
  transition: all 0.3s ease;
  z-index: 1001;
}

.toast.show {
  transform: translateX(-50%) translateY(0);
  opacity: 1;
}

.toast.error {
  background: #E57373;
}

.toast.success {
  background: #81C784;
}

/* ===== 애니메이션 ===== */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10px); }
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

@keyframes glow {
  0% { filter: brightness(1); }
  100% { filter: brightness(1.1); }
}

@keyframes twinkle {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* ===== 빈 상태 ===== */
.empty-state {
  text-align: center;
  padding: 40px;
  color: var(--text-light);
}

.empty-state-icon {
  font-size: 3rem;
  margin-bottom: 15px;
}

/* ===== 반응형 ===== */
@media (max-width: 1100px) {
  .hero-inner {
    gap: 25px;
  }
  
  .hero-image img {
    width: 220px;
    height: 280px;
  }
}

@media (max-width: 900px) {
  .hero-inner {
    flex-wrap: wrap;
    gap: 30px;
  }
  
  .hero-content {
    order: -1;
    width: 100%;
  }
  
  .hero-image img {
    width: 180px;
    height: 230px;
  }
  
  .hero-image-left img,
  .hero-image-right img {
    transform: rotate(0deg);
  }
}

@media (max-width: 768px) {
  .hero {
    padding: 50px 20px;
  }
  
  .hero-title {
    font-size: 2.2rem;
  }
  
  .title-number {
    font-size: 3.5rem;
  }
  
  .hero-image img {
    width: 150px;
    height: 190px;
  }
}

@media (max-width: 500px) {
  .hero-image img {
    width: 120px;
    height: 155px;
  }
  
  .section {
    padding: 25px;
    border-radius: 16px;
  }
  
  .section-title {
    font-size: 1.4rem;
  }
  
  .upload-area {
    padding: 30px;
  }
  
  .media-gallery {
    grid-template-columns: 1fr;
  }
  
  .message-card {
    width: 100%;
    max-width: 300px;
  }
  
  .upload-form {
    flex-direction: column;
  }
  
  .selected-file {
    width: 100%;
  }
}

@media (max-width: 480px) {
  .hero-title {
    font-size: 1.8rem;
  }
  
  .title-number {
    font-size: 2.8rem;
  }
  
  .container {
    padding: 20px 15px;
  }
}
  </style>
</head>
<body>
  <!-- 히어로 섹션 -->
  <header class="hero">
    <div class="spoon-badge">
      <img src="/assets/c__Users_jwnch_AppData_Roaming_Cursor_User_workspaceStorage_da1bc627b220e3d97dcf3b0459da1935_images_image-1e5bcbac-ec23-4b1e-86d0-b6ba36123a68.png" alt="Spoon">
      <span>LIVE</span>
    </div>
    <div class="hero-inner">
      <div class="hero-image hero-image-left">
        <img src="/assets/c__Users_jwnch_AppData_Roaming_Cursor_User_workspaceStorage_da1bc627b220e3d97dcf3b0459da1935_images_image-5dc0f715-0967-49bb-a932-5617d7de3725.png" alt="프로필 이미지 왼쪽">
      </div>
      <div class="hero-content">
        <div class="hearts-decoration">
          <span class="heart">♥</span>
          <span class="heart">♥</span>
          <span class="heart">♥</span>
        </div>
        <h1 class="hero-title">
          <span class="title-number">500</span>일
          <span class="title-text">축하합니다!</span>
        </h1>
        <p class="hero-subtitle">소중한 시간을 함께해주셔서 감사합니다</p>
        <p class="hero-from">- 해랑단 일동 -</p>
        <div class="stars-decoration">
          <span class="star">★</span>
          <span class="star">☆</span>
          <span class="star">★</span>
        </div>
      </div>
      <div class="hero-image hero-image-right">
        <img src="/assets/c__Users_jwnch_AppData_Roaming_Cursor_User_workspaceStorage_da1bc627b220e3d97dcf3b0459da1935_images_image-24079c99-8e82-4316-8664-4345678ca0f1.png" alt="프로필 이미지 오른쪽">
      </div>
    </div>
  </header>

  <main class="container">
    <!-- 미디어 업로드 섹션 -->
    <section class="section media-section">
      <h2 class="section-title">
        <span class="icon">🎬</span>
        축하 영상 & 음성 메시지
      </h2>
      <p class="section-desc">소중한 축하 영상이나 음성 메시지를 남겨주세요!</p>
      
      <div class="upload-area" id="uploadArea">
        <div class="upload-content">
          <div class="upload-icon">📁</div>
          <p class="upload-text">파일을 드래그하거나 클릭하여 업로드</p>
          <p class="upload-hint">동영상 (mp4, webm) 또는 음성 (mp3, wav, m4a)</p>
          <input type="file" id="fileInput" accept="video/*,audio/*" hidden>
        </div>
      </div>
      
      <div class="upload-form" id="uploadForm" style="display: none;">
        <div class="selected-file" id="selectedFile"></div>
        <input type="text" id="mediaNickname" class="input-field" placeholder="닉네임을 입력하세요" maxlength="20">
        <input type="password" id="mediaPassword" class="input-field media-password-input" placeholder="비밀번호 4자리 (수정/삭제용)" maxlength="4" pattern="\d{4}">
        <button class="btn btn-primary" id="uploadBtn">업로드하기</button>
        <button class="btn btn-secondary" id="cancelUploadBtn">취소</button>
      </div>

      <div class="media-gallery" id="mediaGallery">
        <!-- 미디어 카드들이 여기에 표시됩니다 -->
      </div>
    </section>

    <!-- 롤링페이퍼 섹션 -->
    <section class="section rolling-section">
      <div class="section-header">
        <div>
          <h2 class="section-title">
            <span class="icon">💌</span>
            롤링페이퍼
          </h2>
          <p class="section-desc">따뜻한 축하 메시지를 남겨주세요!</p>
        </div>
        <button class="btn btn-my-messages" id="myMessagesBtn">
          <span>📝</span> 내가 쓴 메시지
        </button>
      </div>
      
      <div class="message-form">
        <input type="text" id="messageNickname" class="input-field" placeholder="닉네임" maxlength="20">
        <textarea id="messageContent" class="textarea-field" placeholder="축하 메시지를 작성해주세요..." maxlength="500"></textarea>
        <div class="password-field">
          <input type="password" id="messagePassword" class="input-field" placeholder="비밀번호 4자리 (수정/삭제용)" maxlength="4" pattern="\d{4}">
          <span class="password-hint">숫자 4자리를 입력하세요</span>
        </div>
        <button class="btn btn-primary" id="submitMessageBtn">메시지 남기기</button>
      </div>

      <div class="rolling-paper" id="rollingPaper">
        <!-- 메시지 카드들이 여기에 표시됩니다 -->
      </div>
    </section>
  </main>

  <!-- 푸터 -->
  <footer class="footer">
    <p>Made with ♥ for 500 Days Anniversary</p>
  </footer>

  <!-- 로딩 오버레이 -->
  <div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
    <p>업로드 중...</p>
  </div>

  <!-- 토스트 메시지 -->
  <div class="toast" id="toast"></div>

  <!-- 비밀번호 확인 모달 -->
  <div class="modal-overlay" id="passwordModal">
    <div class="modal">
      <h3 class="modal-title">비밀번호 확인</h3>
      <p class="modal-desc" id="modalDesc">비밀번호 4자리를 입력하세요</p>
      <input type="password" id="modalPassword" class="input-field modal-input" placeholder="비밀번호 4자리" maxlength="4" pattern="\d{4}">
      <div class="modal-actions">
        <button class="btn btn-primary" id="modalConfirmBtn">확인</button>
        <button class="btn btn-secondary" id="modalCancelBtn">취소</button>
      </div>
    </div>
  </div>

  <!-- 내가 쓴 메시지 모달 -->
  <div class="modal-overlay" id="myMessagesModal">
    <div class="modal modal-large">
      <div class="modal-header">
        <h3 class="modal-title">📝 내가 쓴 메시지</h3>
        <button class="modal-close-btn" id="closeMyMessagesBtn">&times;</button>
      </div>
      <div class="my-messages-list" id="myMessagesList">
        <!-- 내가 쓴 메시지가 여기에 표시됩니다 -->
      </div>
    </div>
  </div>

  <script src="js/main.js"></script>
</body>
</html>
